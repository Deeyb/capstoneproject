# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=coderegal_db

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/capstoneproject/google_callback.php

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/capstoneproject

# Security Configuration
SESSION_SECRET=your_random_session_secret_here
CSRF_SECRET=your_random_csrf_secret_here

# Email Configuration (if using SMTP)
# Go-live Checklist (SMTP)
# 1) Use a provider that allows outbound SMTP (e.g., Mailtrap/SendGrid). For Gmail, use an App Password.
# 2) Set SMTP_ENCRYPTION to tls (587) or ssl (465) to match your provider.
# 3) After changing .env, restart your web server.
# 4) Test via Admin > Settings > SMTP Test, then try a Reset Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=Code Regal

# JDoodle API (coding execution / auto-grading)
# 1) Get your client ID and secret from https://www.jdoodle.com/api
# 2) Click Test Connection under Admin > Settings to verify.
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here